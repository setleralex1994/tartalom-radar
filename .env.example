# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# Modellek (alapertelmezetten Claude Opus 4.8). Kolteseg-erzekeny esetben az osszefoglalot
# atallithatod pl. claude-haiku-4-5-re, a tartalomgyartast hagyd Opuson.
CLAUDE_SUMMARY_MODEL=claude-opus-4-8
CLAUDE_CONTENT_MODEL=claude-opus-4-8

# --- Radar beallitasok ---
RADAR_DAYS=7
MIN_RELEVANCE=3

# --- E-mail (heti osszefoglalo kikuldese) ---
# Ugyanaz a mod, mint a Kampany-figyelonel: Gmail + app-jelszo.
GMAIL_USER=setler.alex1994@gmail.com
# GMAIL APP-JELSZO (NEM a rendes jelszavad!). Generalas: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
# Hova menjen a heti osszefoglalo. Ha ures, a GMAIL_USER cimre megy (privat Gmail).
DIGEST_TO=setler.alex1994@gmail.com

# --- Tartalomgyar dashboard ---
PORT=4310
